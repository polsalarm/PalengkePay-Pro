VITE_STELLAR_NETWORK=testnet
VITE_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
VITE_VENDOR_REGISTRY_CONTRACT_ID=C...
VITE_PALENGKE_PAYMENT_CONTRACT_ID=C...
VITE_UTANG_ESCROW_CONTRACT_ID=C...
VITE_UTANG_FEE_XLM=1
# Fee bump — set SPONSOR_SECRET on Vercel dashboard (never commit)
VITE_FEE_BUMP_URL=/api/fee-bump
# Server-only deployment vars:
# SPONSOR_SECRET=SA...
# FEE_BUMP_ALLOWED_DESTINATIONS=G...,G...
# FEE_BUMP_RATE_LIMIT_WINDOW_MS=60000
# FEE_BUMP_RATE_LIMIT_MAX=20
# FEE_BUMP_REQUIRE_DURABLE_RATE_LIMIT=true
# Upstash Redis / Vercel KV-compatible REST limiter. Required for production fee sponsorship.
# Use either the UPSTASH_* names or Vercel KV REST names.
# UPSTASH_REDIS_REST_URL=https://...
# UPSTASH_REDIS_REST_TOKEN=...
# KV_REST_API_URL=https://...
# KV_REST_API_TOKEN=...
# FEE_BUMP_MAX_INNER_XDR_BYTES=20000
# FEE_BUMP_MAX_INNER_FEE_STROOPS=1000
# FEE_BUMP_MAX_SPONSORED_OPS=1
# FEE_BUMP_MAX_SPONSORED_XLM=100
