VITE_STELLAR_NETWORK=testnet
VITE_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
VITE_VENDOR_REGISTRY_CONTRACT_ID=C...
VITE_PALENGKE_PAYMENT_CONTRACT_ID=C...
VITE_UTANG_ESCROW_CONTRACT_ID=C...
VITE_UTANG_FEE_XLM=1
# Fee bump — set SPONSOR_SECRET on Vercel dashboard (never commit)
VITE_FEE_BUMP_URL=/api/fee-bump

# Web Push (VAPID) — generate with `npx web-push generate-vapid-keys`
VITE_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Cron auth — required for production reminder cron
CRON_SECRET=

# Upstash Redis / Vercel KV — optional locally, required for durable production push fan-out
KV_REST_API_URL=
KV_REST_API_TOKEN=
